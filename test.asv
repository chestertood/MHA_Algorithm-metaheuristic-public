% กำหนดฟังก์ชันเป้าหมาย (Sphere Function)
fitnessFunc = @(x) sum(x.^2);

% ขอบเขตของตัวแปร (สมมติเป็นตัวแปร 2 มิติ)
bounds = [-10, 10; -10, 10];

% จำนวนรอบ
max_iter = 100;

% เรียกใช้ฟังก์ชัน
[best_position, best_fitness] = MonsterHunterOptimization(fitnessFunc, bounds, max_iter);

% แสดงผลลัพธ์
disp('Best Position:');
disp(best_position);
disp('Best Fitness:');
disp(best_fitness);
